<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp"
            android:layout_marginTop="16dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/text_secondary"
                android:contentDescription="Back"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- Personal Contact Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERSONAL CONTACT"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="If you miss check-ins, this person will receive an SMS. Make sure they know they're listed and what it means."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp"
            android:lineSpacingMultiplier="1.4"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Contact name (optional)"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="@color/text_secondary"
            app:hintTextColor="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/contactNameField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textPersonName"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Phone number"
            android:layout_marginBottom="24dp"
            app:boxStrokeColor="@color/text_secondary"
            app:hintTextColor="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/contactNumberField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="phone"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Grace Period -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GRACE PERIOD"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/gracePeriodLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alert personal contact after 3 missed days"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.slider.Slider
            android:id="@+id/gracePeriodSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="1"
            android:valueTo="7"
            android:stepSize="1"
            android:value="3"
            android:layout_marginBottom="32dp"
            app:trackColorActive="@color/text_success"
            app:trackColorInactive="@color/card_background"
            app:thumbColor="@color/text_success"/>

        <!-- Crisis Line Info -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CRISIS LINE — DEFAULT"
                    android:textSize="11sp"
                    android:textColor="@color/text_success"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="After 7 missed days, the Belgian Suicide Prevention Line (0800 32 123) will automatically receive an SMS alert. This is always active and requires no setup."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 112 Toggle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMERGENCY SERVICES"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Alert 112 after 10 missed days"
                android:textSize="14sp"
                android:textColor="@color/text_primary"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/enable112Toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"/>
        </LinearLayout>

        <!-- 112 warning -->
        <androidx.cardview.widget.CardView
            android:id="@+id/warningText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#2A1A1A"
            app:cardElevation="0dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="⚠ Only enable this if you are certain. After 10 missed days, emergency services will be contacted. False positives are possible — if you travel, lose your phone, or forget, this will trigger. Your personal contact will also receive an urgent SMS."
                android:textSize="13sp"
                android:textColor="#FF6B6B"
                android:lineSpacingMultiplier="1.4"/>
        </androidx.cardview.widget.CardView>

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Settings"
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/button_checked"/>

    </LinearLayout>
</ScrollView>
